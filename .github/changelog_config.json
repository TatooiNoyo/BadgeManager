{
  "categories": [
    {
      "title": "🚀 Features",
      "labels": ["feature", "feat"]
    },
    {
      "title": "🐛 Fixes",
      "labels": ["fix", "bug"]
    },
    {
      "title": "🧪 Tests",
      "labels": ["test"]
    },
    {
      "title": "⚙️ Build & CI",
      "labels": ["build", "ci"]
    },
    {
      "title": "📝 Documentation",
      "labels": ["docs"]
    },
    {
      "title": "🧱 Refactoring",
      "labels": ["refactor"]
    },
    {
      "title": "🧹 Chore",
      "labels": ["chore", "style", "perf", "revert"]
    },
    {
      "title": "📦 Other",
      "labels": []
    }
  ],
  "ignore_labels": ["ignore"],
  "sort": "ASC",
  "template": "#{{CHANGELOG}}",
  "pr_template": "- #{{TITLE}} @#{{AUTHOR}}",
  "commit_template": "- #{{TITLE}} @#{{AUTHOR}}",
  "empty_template": "No significant changes in this release.",
  "label_extractor": [
    {
      "pattern": "^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\\([\\w\\-\\.]+\\))?(!)?: ([\\w ])+([\\s\\S]*)",
      "on_property": "title",
      "target": "$1",
      "flags": "iu",
      "method": "replace"
    }
  ],
  "max_pull_requests": 1000,
  "max_back_track_time_days": 1000
}
